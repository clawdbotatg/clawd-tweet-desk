# Copy to .env and fill in. .env is gitignored — NEVER commit real keys.

# Twitter API (OAuth 1.0a user context — needed to post as the account)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Optional: OAuth2 bearer for read-only endpoints (search, lookups)
TWITTER_BEARER_TOKEN=

# Telegram bot (coordination channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# The handle we post as (used for links + sanity checks)
TWITTER_HANDLE=
